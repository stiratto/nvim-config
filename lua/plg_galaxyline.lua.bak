local gl = require('galaxyline')
local gls = gl.section
gl.short_line_list = {'LuaTree', 'vista', 'dbui'}

-- Colores adaptados a Gruvbox
local colors = {
  bg = '#3c3836', -- Color de fondo
  fg = '#ebdbb2', -- Color de primer plano
  yellow = '#fabd2f', -- Color amarillo
  cyan = '#8ec07c', -- Color cyan
  darkblue = '#458588', -- Color azul oscuro
  green = '#b8bb26', -- Color verde
  orange = '#fe8019', -- Color naranja
  -- purple = '#d3869b', -- Color púrpura eliminado
  magenta = '#d65d0e', -- Color magenta
  grey = '#7c6f64', -- Color gris
  blue = '#83a598', -- Color azul
  red = '#fb4934' -- Color rojo
}
local gl = require('galaxyline')
local gls = gl.section
gl.short_line_list = {'LuaTree', 'vista', 'dbui'}



local buffer_not_empty = function()
  if vim.fn.empty(vim.fn.expand('%:t')) ~= 1 then
    return true
  end
  return false
end

gls.left[1] = {
  FirstElement = {
    provider = function() return '▋' end,
    highlight = {colors.blue, colors.bg}
  },
}

gls.left[2] = {
  Space1 = {
    provider = function() return ' ' end, -- Espacio antes del modo
    highlight = {colors.grey, colors.bg} -- Cambia los colores aquí
  },
}

gls.left[3] = {
  ViMode = {
    provider = function()
      local alias = {n = 'NORMAL', i = 'INSERT', c = 'COMMAND', v = 'VISUAL', V = 'VISUAL LINE', [''] = 'VISUAL BLOCK'}
      return alias[vim.fn.mode()]
    end,
    separator_highlight = {colors.orange, colors.bg}, -- Cambiado a verde
    highlight = {colors.darkblue, colors.bg, 'bold'}, -- Cambiado a verde
  },
}

gls.left[4] = {
  Space2 = {
    provider = function() return ' ' end, -- Espacio después del modo
    highlight = {colors.grey, colors.bg} -- Cambia los colores aquí
  },
}

gls.left[5] = {
  FileIcon = {
    provider = 'FileIcon',
    condition = buffer_not_empty,
    highlight = {require('galaxyline.provider_fileinfo').get_file_icon_color, colors.bg}, -- Color del icono de archivo
  },
}

gls.left[6] = {
  Space3 = {
    provider = function() return ' ' end, -- Espacio después del icono del archivo
    highlight = {colors.grey, colors.bg} -- Cambia los colores aquí
  },
}

gls.left[7] = {
  FileName = {
    provider = {'FileName', 'FileSize'},
    condition = buffer_not_empty,
    separator_highlight = {colors.yellow, colors.bg}, -- Cambiado a amarillo
    highlight = {colors.magenta, colors.bg} -- Color del nombre del archivo
  }
}

