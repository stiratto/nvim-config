  }
}
gls.left[9] = {
  DiffRemove = {
    provider = 'DiffRemove',
    condition = checkwidth,
    icon = ' ',
    highlight = {colors.red, colors.bg}, -- Color de eliminado
  }
}
gls.left[10] = {
  LeftEnd = {
    provider = function() return '' end,
    separator_highlight = {colors.green, colors.bg}, -- Cambiado a verde
    highlight = {colors.green, colors.bg} -- Cambiado a verde
  }
}
gls.left[11] = {
  DiagnosticError = {
    provider = 'DiagnosticError',
    icon = '  ',
    highlight = {colors.red, colors.bg} -- Color de error
  }
}
gls.left[12] = {
  Space = {
    provider = function() return ' ' end,
    highlight = {colors.grey, colors.bg} -- Cambia los colores aquí
  }
}
gls.left[13] = {
  DiagnosticWarn = {
    provider = 'DiagnosticWarn',
    icon = '  ',
    highlight = {colors.blue, colors.bg}, -- Color de advertencia
  }
}
gls.right[2] = {
  LineInfo = {
    provider = 'LineColumn',
    separator = ' ',
    separator_highlight = {colors.darkblue, colors.bg}, -- Cambiado a verde
    highlight = {colors.grey, colors.bg}, -- Cambiado a verde
  },
}

gls.right[4] = {
  ScrollBar = {
    provider = 'ScrollBar',
    highlight = {colors.yellow, colors.bg}, -- Cambiado a verde
  }
}

gls.short_line_left[1] = {
  BufferType = {
    provider = 'FileTypeName',
    separator_highlight = {colors.orange, colors.bg}, -- Cambiado a verde
    highlight = {colors.grey, colors.green} -- Cambiado a verde
  }
}

gls.short_line_right[1] = {
  BufferIcon = {
